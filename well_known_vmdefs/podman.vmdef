#!/bin/env python3

VMDEF_VERSION = 1
NAME = 'podman'
REQUIRES = 'alpine_linux_with_ssh'

_BUILD_SCRIPT = '''
echo ===============
echo Entering chroot
echo ===============
echo
chroot _CHROOT /bin/ash <<CHROOTEOF || exit $?
  echo =========================
  echo Installing podman package
  echo =========================
  apk add podman || exit $?
  echo

  echo =======================
  echo Enabling podman service
  echo =======================
  rc-update add podman || exit $?
  echo
CHROOTEOF
'''

def BUILD(vm):
  vm.super().BUILD(vm)
  script = _BUILD_SCRIPT.replace('_CHROOT', get_chroot())
  vm.pipe_shell(script, echo_output = True, check = True)

__import__('virtuator').handle()
